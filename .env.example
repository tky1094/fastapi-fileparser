# LLM Provider: "anthropic", "openai", "ollama", or "vllm"
APP_LLM_PROVIDER=anthropic

# Anthropic
APP_ANTHROPIC_API_KEY=sk-ant-xxxxx
APP_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
APP_OPENAI_API_KEY=sk-xxxxx
APP_OPENAI_MODEL=gpt-4o

# Ollama (OpenAI-compatible endpoint)
APP_OLLAMA_BASE_URL=http://localhost:11434/v1
APP_OLLAMA_MODEL=llava

# vLLM (OpenAI-compatible endpoint)
APP_VLLM_BASE_URL=http://localhost:8000/v1
APP_VLLM_MODEL=

# PDF
APP_PDF_MAX_CONCURRENCY=3

# App
APP_MAX_UPLOAD_SIZE_MB=20
APP_LOG_LEVEL=INFO
